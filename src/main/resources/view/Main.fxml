<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane
  xmlns="http://javafx.com/javafx/21"
  xmlns:fx="http://javafx.com/fxml/1"
  fx:controller="com.bookstore.presentation.controller.MainController"
  stylesheets="@/css/main.css"
  style="-fx-background-color: #0f0f13;">

  <left>
    <VBox styleClass="sidebar" spacing="4">

      <VBox spacing="4" style="-fx-padding: 0 0 16 0;">
        <Label text="📚 BookStore"
          style="-fx-text-fill: #e8e6f0; -fx-font-size: 16px; -fx-font-weight: bold;"/>
        <Label fx:id="userRoleLabel" text="Касир" styleClass="label-secondary"/>
      </VBox>

      <Separator style="-fx-padding: 0 0 8 0;"/>

      <Label text="ГОЛОВНЕ" styleClass="label-secondary"
        style="-fx-font-size: 10px; -fx-padding: 8 0 4 8;"/>

      <Button fx:id="btnClients" text="👥  Клієнти"
        styleClass="sidebar-item" onAction="#showClients"/>
      <Button fx:id="btnBooks" text="📖  Книги"
        styleClass="sidebar-item" onAction="#showBooks"/>
      <Button fx:id="btnSales" text="🧾  Продажі"
        styleClass="sidebar-item" onAction="#showSales"/>

      <Label text="УПРАВЛІННЯ" styleClass="label-secondary"
        style="-fx-font-size: 10px; -fx-padding: 16 0 4 8;"/>

      <Button fx:id="btnCategories" text="🏷  Категорії"
        styleClass="sidebar-item" onAction="#showCategories"/>
      <Button fx:id="btnAuthors" text="✍️  Автори"
        styleClass="sidebar-item" onAction="#showAuthors"/>
      <Button fx:id="btnSuppliers" text="🚚  Постачальники"
        styleClass="sidebar-item" onAction="#showSuppliers"/>
      <Button fx:id="btnSupplies" text="📦  Постачання"
        styleClass="sidebar-item" onAction="#showSupplies"/>

      <Region VBox.vgrow="ALWAYS"/>

      <Separator/>

      <VBox spacing="8" style="-fx-padding: 8 0 0 0;">
        <Label fx:id="usernameLabel" text="username"
          style="-fx-text-fill: #e8e6f0; -fx-font-size: 13px;"/>
        <Button text="🚪  Вийти"
          styleClass="sidebar-item" onAction="#handleLogout"/>
      </VBox>

    </VBox>
  </left>

  <center>
    <StackPane fx:id="contentArea" style="-fx-background-color: #0f0f13;"/>
  </center>

</BorderPane>