<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<StackPane
  xmlns="http://javafx.com/javafx/21"
  xmlns:fx="http://javafx.com/fxml/1"
  fx:controller="com.bookstore.presentation.controller.LoginController"
  stylesheets="@/css/main.css"
  style="-fx-background-color: #0f0f13;">

  <VBox alignment="CENTER" spacing="0" maxWidth="400">

    <VBox alignment="CENTER" spacing="8">
      <Label text="📚" style="-fx-font-size: 48px;"/>
      <Label text="BookStore" styleClass="label-title"
        style="-fx-font-size: 28px; -fx-font-weight: bold;"/>
      <Label text="Система обліку книжкового магазину"
        styleClass="label-subtitle"/>
    </VBox>

    <Region prefHeight="32"/>

    <VBox styleClass="card" spacing="20">

      <Label text="Вхід до системи"
        style="-fx-text-fill: #e8e6f0; -fx-font-size: 18px; -fx-font-weight: bold;"/>

      <VBox spacing="6">
        <Label text="Логін" styleClass="label-secondary"/>
        <TextField fx:id="usernameField"
          promptText="Введіть логін"
          styleClass="text-field"/>
      </VBox>

      <VBox spacing="6">
        <Label text="Пароль" styleClass="label-secondary"/>
        <PasswordField fx:id="passwordField"
          promptText="Введіть пароль"
          styleClass="password-field"/>
      </VBox>

      <Label fx:id="errorLabel"
        styleClass="label-error"
        text=""
        wrapText="true"
        managed="false"
        visible="false"/>

      <Button fx:id="loginButton"
        text="Увійти"
        styleClass="btn-primary"
        maxWidth="Infinity"
        onAction="#handleLogin"/>

      <HBox alignment="CENTER" spacing="8">
        <Region HBox.hgrow="ALWAYS"
          style="-fx-border-color: #2e2e40; -fx-border-width: 0 0 1 0;"/>
        <Label text="або" styleClass="label-secondary"/>
        <Region HBox.hgrow="ALWAYS"
          style="-fx-border-color: #2e2e40; -fx-border-width: 0 0 1 0;"/>
      </HBox>

      <HBox alignment="CENTER" spacing="6">
        <Label text="Немає акаунту?" styleClass="label-secondary"/>
        <Label text="Зареєструватися"
          styleClass="link-label"
          onMouseClicked="#handleGoToRegister"/>
      </HBox>

    </VBox>

  </VBox>

</StackPane>