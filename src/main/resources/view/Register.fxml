<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<StackPane
  xmlns="http://javafx.com/javafx/21"
  xmlns:fx="http://javafx.com/fxml/1"
  fx:controller="com.bookstore.presentation.controller.RegisterController"
  stylesheets="@/css/main.css"
  style="-fx-background-color: #0f0f13;"
  alignment="CENTER"> <VBox alignment="CENTER" spacing="0" maxWidth="420" fillWidth="true">

  <VBox alignment="CENTER" spacing="8">
    <Label text="📚" style="-fx-font-size: 40px;"/>
    <Label text="Реєстрація" styleClass="label-title"
      style="-fx-font-size: 24px;"/>
    <Label text="Створіть новий акаунт"
      styleClass="label-subtitle"/>
  </VBox>

  <Region prefHeight="20"/>

  <VBox styleClass="card" spacing="12"> <VBox spacing="4">
    <Label text="Логін" styleClass="label-secondary"/>
    <TextField fx:id="usernameField"
      promptText="Мінімум 3 символи"
      styleClass="text-field"/>
    <Label fx:id="usernameError" styleClass="label-error"
      text="" visible="false" managed="false"/>
  </VBox>

    <VBox spacing="4">
      <Label text="Email" styleClass="label-secondary"/>
      <TextField fx:id="emailField"
        promptText="example@email.com"
        styleClass="text-field"/>
      <Label fx:id="emailError" styleClass="label-error"
        text="" visible="false" managed="false"/>
    </VBox>

    <VBox spacing="4">
      <Label text="Пароль" styleClass="label-secondary"/>
      <PasswordField fx:id="passwordField"
        promptText="Мінімум 6 символів"
        styleClass="password-field"/>
      <Label fx:id="passwordError" styleClass="label-error"
        text="" visible="false" managed="false"/>
    </VBox>

    <VBox spacing="4">
      <Label text="Підтвердження паролю" styleClass="label-secondary"/>
      <PasswordField fx:id="confirmPasswordField"
        promptText="Повторіть пароль"
        styleClass="password-field"/>
      <Label fx:id="confirmPasswordError" styleClass="label-error"
        text="" visible="false" managed="false"/>
    </VBox>

    <VBox spacing="4">
      <Label text="Роль" styleClass="label-secondary"/>
      <ComboBox fx:id="roleComboBox"
        promptText="Оберіть роль"
        styleClass="combo-box"
        maxWidth="Infinity"/>
    </VBox>

    <Label fx:id="generalError"
      styleClass="label-error"
      text=""
      wrapText="true"
      visible="false"
      managed="false"/>

    <Button fx:id="registerButton"
      text="Зареєструватися"
      styleClass="btn-primary"
      maxWidth="Infinity"
      onAction="#handleRegister"/>

    <HBox alignment="CENTER" spacing="6">
      <Label text="Вже є акаунт?" styleClass="label-secondary"/>
      <Label text="Увійти"
        styleClass="link-label"
        onMouseClicked="#handleGoToLogin"
        style="-fx-cursor: hand;"/> </HBox>

  </VBox>

</VBox>

</StackPane>